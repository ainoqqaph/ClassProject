                      <xs:element name="ExecutionDate" msprop:FriendlyName="ExecutionDate" msprop:DbColumnName="ExecutionDate" msprop:design-time-name="f8538ff6-b41d-4658-b4f4-508e09293eec" type="xs:dateTime" />
                      <xs:element name="StartTime" msprop:FriendlyName="StartTime" msprop:DbColumnName="StartTime" msprop:design-time-name="c911ee89-cb59-4427-bf0d-3380470dd621" type="xs:dateTime" />
