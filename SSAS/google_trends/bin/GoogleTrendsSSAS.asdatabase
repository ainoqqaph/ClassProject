      <MdxScripts>
        <MdxScript>
          <ID>MdxScript</ID>
          <Name>MdxScript</Name>
          <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
          <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
          <Commands>
            <Command>
              <Text>CALCULATE;  

CREATE MEMBER CURRENTCUBE.[Measures].[Avg Overall Quality Score]
 AS IIF( [Measures].[Fact Quality Metrics 計數]= 0, NULL, 
        [Measures].[Overall Quality Score] / [Measures].[Fact Quality Metrics 計數]), 
FORMAT_STRING = "0.00%", 
VISIBLE = 1  ; </Text>
            </Command>
          </Commands>
        </MdxScript>
      </MdxScripts>
