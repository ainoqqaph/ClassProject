                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="ErrorMessage" msprop:FriendlyName="ErrorMessage" msprop:DbColumnName="ErrorMessage" msprop:design-time-name="b10b7b02-5ed1-4559-9b35-c625c814c41b" type="xs:string" minOccurs="0" />
                      <xs:element name="CrawlerVersion" msprop:FriendlyName="CrawlerVersion" msprop:DbColumnName="CrawlerVersion" msprop:design-time-name="ac1c4bb3-3b4b-46c0-9e29-342f15950b57" minOccurs="0">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="PythonVersion" msprop:FriendlyName="PythonVersion" msprop:DbColumnName="PythonVersion" msprop:design-time-name="3da0ab9d-6623-48e7-9d01-2e343c08c9a8" minOccurs="0">
                        <xs:simpleType>
