                      <xs:element name="CreatedAt" msprop:FriendlyName="CreatedAt" msprop:DbColumnName="CreatedAt" msprop:design-time-name="a84be72a-a4d1-4a9f-9089-e241af1922cb" type="xs:dateTime" minOccurs="0" />
                      <xs:element name="UpdatedAt" msprop:FriendlyName="UpdatedAt" msprop:DbColumnName="UpdatedAt" msprop:design-time-name="686fd389-786b-4924-b721-5436b4339906" type="xs:dateTime" minOccurs="0" />
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="dbo_KeywordsMaster" msprop:DbSchemaName="dbo" msprop:design-time-name="85ccd69b-8d7c-4cb2-bb13-4738fea64406" msprop:FriendlyName="KeywordsMaster" msprop:TableType="Table" msprop:DbTableName="KeywordsMaster">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="KeywordID" msprop:FriendlyName="KeywordID" msprop:DbColumnName="KeywordID" msprop:design-time-name="6118b19b-75f6-483f-9c10-4c69cc803372" type="xs:int" />
                      <xs:element name="Keyword" msprop:FriendlyName="Keyword" msprop:DbColumnName="Keyword" msprop:design-time-name="750c9c05-b40b-417f-9794-c6417c6b1b80">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="200" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Category" msprop:FriendlyName="Category" msprop:DbColumnName="Category" msprop:design-time-name="49bcbb45-4421-447e-b350-8b92dcee8655" minOccurs="0">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="SearchIntent" msprop:FriendlyName="SearchIntent" msprop:DbColumnName="SearchIntent" msprop:design-time-name="894140d5-61aa-4745-9646-446209911cc5" minOccurs="0">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="50" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="CreatedAt" msprop:FriendlyName="CreatedAt" msprop:DbColumnName="CreatedAt" msprop:design-time-name="1819c930-bfca-461d-bb39-7e4a8c7786e0" type="xs:dateTime" minOccurs="0" />
                      <xs:element name="Language" msdata:ReadOnly="true" msprop:DbColumnName="Language" msprop:IsLogical="True" msprop:ComputedColumnExpression="CASE &#xD;&#xA;    WHEN UNICODE(SUBSTRING(Keyword, 1, 1)) &gt; 255 THEN N'中文'&#xD;&#xA;    ELSE N'英文'&#xD;&#xA;END" msprop:design-time-name="edefe24d-79bd-481e-8ecd-173857cf8a42" msprop:Description="">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="2" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="KeywordLength" msdata:ReadOnly="true" msprop:DbColumnName="KeywordLength" msprop:IsLogical="True" msprop:ComputedColumnExpression="CASE &#xD;&#xA;    WHEN LEN(Keyword) &lt;= 5 THEN N'短'&#xD;&#xA;    WHEN LEN(Keyword) &lt;= 15 THEN N'中'&#xD;&#xA;    ELSE N'長'&#xD;&#xA;END" msprop:design-time-name="9443bc9a-f6a8-4085-b8e3-a283b95609a1" msprop:Description="">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="1" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="dbo_RegionsMaster" msprop:DbSchemaName="dbo" msprop:design-time-name="6c4ddf45-e1c7-45e4-9784-28fc87646e71" msprop:FriendlyName="RegionsMaster" msprop:TableType="Table" msprop:DbTableName="RegionsMaster">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="RegionID" msprop:FriendlyName="RegionID" msprop:DbColumnName="RegionID" msprop:design-time-name="34463387-7300-483a-86f4-bce1cd85521c" type="xs:int" />
                      <xs:element name="RegionCode" msprop:FriendlyName="RegionCode" msprop:DbColumnName="RegionCode" msprop:design-time-name="7fbdadba-d802-4634-a8b2-c62f1df8f971">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="10" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="RegionName" msprop:FriendlyName="RegionName" msprop:DbColumnName="RegionName" msprop:design-time-name="6b2a0e75-add6-4b2f-a750-8a4ff2054855">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="100" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="CreatedAt" msprop:FriendlyName="CreatedAt" msprop:DbColumnName="CreatedAt" msprop:design-time-name="a03a3472-51e6-497e-8b1d-2b61791a1569" type="xs:dateTime" minOccurs="0" />
                      <xs:element name="RegionGroup" msdata:ReadOnly="true" msprop:DbColumnName="RegionGroup" msprop:IsLogical="True" msprop:ComputedColumnExpression="CASE &#xD;&#xA;    WHEN RegionCode IN ('US', 'GB', 'AU') THEN N'英語系'&#xD;&#xA;    WHEN RegionCode IN ('TW', 'HK') THEN N'華語系'&#xD;&#xA;    WHEN RegionCode = 'ES' THEN N'西語系'&#xD;&#xA;    ELSE N'其他'&#xD;&#xA;END" msprop:design-time-name="dd3836ea-1e88-404a-b8b7-d102a3764df1" msprop:Description="">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="3" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="Continent" msdata:ReadOnly="true" msprop:DbColumnName="Continent" msprop:IsLogical="True" msprop:ComputedColumnExpression="CASE &#xD;&#xA;    WHEN RegionCode = 'US' THEN N'北美洲'&#xD;&#xA;    WHEN RegionCode IN ('GB', 'ES') THEN N'歐洲'&#xD;&#xA;    WHEN RegionCode = 'AU' THEN N'大洋洲'&#xD;&#xA;    WHEN RegionCode IN ('TW', 'HK') THEN N'亞洲'&#xD;&#xA;    ELSE N'其他'&#xD;&#xA;END" msprop:design-time-name="3fa2b0b8-6cc2-4b4d-af6d-c89b4eb0d79c" msprop:Description="">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="3" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="DimTrendDirection" msprop:QueryBuilder="GenericQueryBuilder" msprop:IsLogical="True" msprop:design-time-name="c100bc80-2c86-4e0e-ac12-e0547ae93c95" msprop:QueryDefinition="SELECT &#xD;&#xA;    ROW_NUMBER() OVER (ORDER BY SortOrder) AS TrendDirectionKey,&#xD;&#xA;    TrendDirectionCode,&#xD;&#xA;    TrendDirectionName&#xD;&#xA;FROM (&#xD;&#xA;    VALUES &#xD;&#xA;        ('NEW', N'新上榜', 1),&#xD;&#xA;        ('RISING', N'上升', 2),&#xD;&#xA;        ('FALLING', N'下降', 3),&#xD;&#xA;        ('STABLE', N'持平', 4),&#xD;&#xA;        ('UNKNOWN', N'未知', 5)&#xD;&#xA;) AS T(TrendDirectionCode, TrendDirectionName, SortOrder)" msprop:FriendlyName="DimTrendDirection" msprop:TableType="View" msprop:DbTableName="DimTrendDirection" msprop:Description="">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="TrendDirectionKey" msdata:ReadOnly="true" msprop:FriendlyName="TrendDirectionKey" msprop:DbColumnName="TrendDirectionKey" msprop:design-time-name="88862825-e4de-4ce3-adb2-11746c2dceee" type="xs:long" minOccurs="0" />
                      <xs:element name="TrendDirectionCode" msdata:ReadOnly="true" msprop:FriendlyName="TrendDirectionCode" msprop:DbColumnName="TrendDirectionCode" msprop:design-time-name="78b78219-b206-4b6a-b9d1-d91222693ff9">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="7" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="TrendDirectionName" msdata:ReadOnly="true" msprop:FriendlyName="TrendDirectionName" msprop:DbColumnName="TrendDirectionName" msprop:design-time-name="a5e42df3-2595-4a0b-a709-1bb527107c3a" minOccurs="0">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="3" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="DimCategory" msprop:QueryBuilder="GenericQueryBuilder" msprop:IsLogical="True" msprop:design-time-name="622c5b57-9826-4128-9f3f-c33b006b3f59" msprop:QueryDefinition="SELECT &#xD;&#xA;    ROW_NUMBER() OVER (ORDER BY SortOrder) AS CategoryKey,&#xD;&#xA;    CategoryCode,&#xD;&#xA;    CategoryName&#xD;&#xA;FROM (&#xD;&#xA;    VALUES &#xD;&#xA;        ('Technology', N'科技', 1),&#xD;&#xA;        ('Entertainment', N'娛樂', 2),&#xD;&#xA;        ('Sports', N'運動', 3),&#xD;&#xA;        ('Politics', N'政治', 4),&#xD;&#xA;        ('Business', N'商業', 5),&#xD;&#xA;        ('Health', N'健康', 6),&#xD;&#xA;        ('Education', N'教育', 7),&#xD;&#xA;        ('Lifestyle', N'生活', 8),&#xD;&#xA;        ('News', N'新聞', 9),&#xD;&#xA;        ('Other', N'其他', 10)&#xD;&#xA;) AS T(CategoryCode, CategoryName, SortOrder)" msprop:FriendlyName="DimCategory" msprop:TableType="View" msprop:DbTableName="DimCategory" msprop:Description="">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="CategoryKey" msdata:ReadOnly="true" msprop:FriendlyName="CategoryKey" msprop:DbColumnName="CategoryKey" msprop:design-time-name="cea6c51f-65c2-4ba7-8abd-ff4c77245b9b" type="xs:long" minOccurs="0" />
                      <xs:element name="CategoryCode" msdata:ReadOnly="true" msprop:FriendlyName="CategoryCode" msprop:DbColumnName="CategoryCode" msprop:design-time-name="0574a4ee-97cb-4ba9-af08-301241fbe9f6">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="13" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                      <xs:element name="CategoryName" msdata:ReadOnly="true" msprop:FriendlyName="CategoryName" msprop:DbColumnName="CategoryName" msprop:design-time-name="de439a4a-d86b-4adf-b9ac-a4fb4a76c82c" minOccurs="0">
                        <xs:simpleType>
                          <xs:restriction base="xs:string">
                            <xs:maxLength value="2" />
                          </xs:restriction>
                        </xs:simpleType>
                      </xs:element>
                    </xs:sequence>
