                      <xs:element name="DurationSeconds" msprop:FriendlyName="DurationSeconds" msprop:DbColumnName="DurationSeconds" msprop:design-time-name="5b4b1e49-d96c-43b6-a44c-e727a4d2c325" type="xs:int" minOccurs="0" />
                      <xs:element name="RegionsScraped" msprop:FriendlyName="RegionsScraped" msprop:DbColumnName="RegionsScraped" msprop:design-time-name="24a32da2-7855-44bc-8b80-38ef85e802d8" type="xs:int" minOccurs="0" />
                      <xs:element name="TotalKeywordsFound" msprop:FriendlyName="TotalKeywordsFound" msprop:DbColumnName="TotalKeywordsFound" msprop:design-time-name="e2f9a243-015e-43ac-9103-ac978c5fee54" type="xs:int" minOccurs="0" />
                      <xs:element name="NewKeywordsAdded" msprop:FriendlyName="NewKeywordsAdded" msprop:DbColumnName="NewKeywordsAdded" msprop:design-time-name="d8c16fe6-9a3d-4b6a-88e4-9eb20194ae6b" type="xs:int" minOccurs="0" />
                      <xs:element name="KeywordsSearched" msprop:FriendlyName="KeywordsSearched" msprop:DbColumnName="KeywordsSearched" msprop:design-time-name="86aba22b-8876-4d86-8a65-f83b21b1e675" type="xs:int" minOccurs="0" />
                      <xs:element name="Status" msprop:FriendlyName="Status" msprop:DbColumnName="Status" msprop:design-time-name="193934a3-353f-4383-9cc5-29d4cf3a4540" minOccurs="0">
